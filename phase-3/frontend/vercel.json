{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "https://loanvati-1.onrender.com/api/v1"
  },
  "regions": ["sfo1"],
  "rewrites": [
    {
      "source": "/:path((?!_next/static|_next/image|favicon.ico).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [],
  "version": 2
}
